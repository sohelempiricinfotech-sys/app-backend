{
  "swagger": "2.0",
  "info": {
    "title": "App Backend Admin API",
    "version": "2026.07.08",
    "description": "Internal admin API contract for app-backend."
  },
  "host": "api.example.test",
  "basePath": "/",
  "schemes": ["https"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "paths": {
    "/admin/reports/daily": {
      "get": {
        "tags": ["admin"],
        "operationId": "getDailyReport",
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": true,
            "type": "string",
            "format": "date"
          }
        ],
        "responses": {
          "200": {
            "description": "Daily report",
            "schema": {
              "$ref": "#/definitions/DailyReportResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        }
      }
    },
    "/admin/reports/export": {
      "post": {
        "tags": ["admin"],
        "operationId": "exportReport",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ExportReportRequest"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Export job accepted",
            "schema": {
              "$ref": "#/definitions/ExportJob"
            }
          },
          "400": {
            "description": "Invalid export request",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "DailyReportResponse": {
      "type": "object",
      "required": ["date", "totalUsers", "totalRevenue"],
      "additionalProperties": false,
      "properties": {
        "date": { "type": "string", "format": "date" },
        "totalUsers": { "type": "integer", "minimum": 0 },
        "totalRevenue": { "type": "number", "minimum": 0 }
      }
    },
    "ExportReportRequest": {
      "type": "object",
      "required": ["format", "dateRange"],
      "additionalProperties": false,
      "properties": {
        "format": {
          "type": "string",
          "enum": ["csv", "xlsx"]
        },
        "dateRange": {
          "type": "object",
          "required": ["from", "to"],
          "additionalProperties": false,
          "properties": {
            "from": { "type": "string", "format": "date" },
            "to": { "type": "string", "format": "date" }
          }
        }
      }
    },
    "ExportJob": {
      "type": "object",
      "required": ["jobId", "status"],
      "additionalProperties": false,
      "properties": {
        "jobId": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["queued", "processing"]
        }
      }
    }
  }
}

